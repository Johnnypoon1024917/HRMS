# Root environment overrides for `docker compose up`.
# Copy to `.env` and fill in real values for any non-local deployment.
# Compose substitutes these into docker-compose.yml; unset values fall back
# to the dev defaults baked into the compose file.

# --- Database (used by db, init, and api services) ---
POSTGRES_USER=hrms
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=hrms

# --- Auth ---
# REQUIRED in production. Generate with: openssl rand -base64 48
JWT_SECRET=

# --- Billing (Stripe). Leave blank to run billing in dry-run mode. ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- On-prem licensing (SaaS deploys can ignore) ---
LICENSE_PUBLIC_KEY=
LICENSE_KEY=
SINGLE_TENANT=

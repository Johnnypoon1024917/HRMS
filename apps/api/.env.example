# Base connection (schema is appended per tenant at runtime)
DATABASE_URL="postgresql://hrms:hrms@localhost:5432/hrms"
REGISTRY_SCHEMA="public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="dev-secret-change-me"
PORT=4000

# Public URLs for the SSO round-trip
API_PUBLIC_URL="http://localhost:4000"
WEB_PUBLIC_URL="http://localhost:5000"

# Env-level fallback IdP (used when a tenant has no `idp` config row).
# Per-tenant OIDC is configured in registry tenant.idp (overrides these).
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""

# SaaS subscription billing (Scope C). Leave blank to run in dry-run mode
# (checkout/portal return a fake URL; webhook is disabled).
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# On-prem licensing. The operator side signs with the private key; on-prem
# api bundles the public key and the per-customer LICENSE_KEY (JWT).
LICENSE_PRIVATE_KEY=""
LICENSE_PUBLIC_KEY=""
LICENSE_KEY=""

# Deployment mode: "saas" resolves tenant from sub-domain;
# "onprem" pins to SINGLE_TENANT.
DEPLOYMENT_MODE="saas"
SINGLE_TENANT=""
